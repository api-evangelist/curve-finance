          },
          "docs": "Returns all base APY data for Curve pools on each chain.\n\nNote: [`/getVolumes/{blockchainId}`](#/default/get_getVolumes__blockchainId_) is preferred\n"
        },
        {
          "info": {
            "name": "GET /getFactoGaugesCrvRewards/{blockchainId}",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.curve.finance/v1/getFactoGaugesCrvRewards/:blockchainId",
            "params": [
