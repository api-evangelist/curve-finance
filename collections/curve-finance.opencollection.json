            "params": [
              {
                "name": "blockchainId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns addresses of all pools, in all registries, on a specific chain.\n\nNote: For backward compatibility, in this endpoint the \"factory\" registry is renamed to \"stable-factory\"\n"
        },
